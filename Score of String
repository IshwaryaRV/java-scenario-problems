import java.io.*;
import java.util.*;
public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.nextLine();
        int score = 0;
        for(int i=0;i<s.length()-1;i++){
            int diff = s.charAt(i) - s.charAt(i + 1);
            if (diff < 0) {
                diff = -diff; 
            }
            score += diff;
        }
         System.out.println(score);
    }
}
